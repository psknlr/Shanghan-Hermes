{"formula_pattern_rule_id": "FPR_0022", "formula": "小柴胡湯", "formula_family": "柴胡湯", "six_channel_scope": ["太陽病", "陽明病", "少陽病", "厥陰病", "陰陽易差後勞復病"], "core_pattern": "中風類證", "core_symptoms": ["往來寒熱", "嘔", "不欲飲食", "渴", "惡風", "手足溫", "不能食", "頸項強"], "core_pulse": ["弦", "沉緊"], "associated_symptoms": ["小便難", "潮熱", "發熱", "心煩喜嘔", "腹中痛", "心下悸", "小便不利", "不渴"], "associated_pulse": ["遲浮弱", "浮遲弱", "細", "沉"], "contraindications": [], "composition": [{"herb": "柴胡", "dose_processing": "半斤"}, {"herb": "黃芩", "dose_processing": "三兩"}, {"herb": "人參", "dose_processing": "三兩"}, {"herb": "半夏", "dose_processing": "半升，洗"}, {"herb": "甘草", "dose_processing": "炙"}, {"herb": "生薑", "dose_processing": "切，各三兩"}, {"herb": "大棗", "dose_processing": "十二枚，擘"}], "administration_notes": ["溫服一升，日三服。若胸中煩而不嘔者，去半夏、人參，加栝蔞實一枚。若渴，去半夏，加人參合前成四兩半、栝蔞根四兩。若腹中痛者，去黃芩，加芍藥三兩。若脇下痞鞕，去大棗，加牡蠣四兩。若心下悸、小便不利者，去黃芩，加茯苓四兩。若不渴、外有微熱者，去人"], "modification_relations": [], "supporting_initial_rules": ["IR_SHL_0096_001", "IR_SHL_0097_001", "IR_SHL_0098_001", "IR_SHL_0099_001", "IR_SHL_0100_001", "IR_SHL_0101_001", "IR_SHL_0144_002", "IR_SHL_0148_002", "IR_SHL_0229_001", "IR_SHL_0230_001", "IR_SHL_0231_001", "IR_SHL_0266_001", "IR_SHL_0267_002", "IR_SHL_0379_001", "IR_SHL_0394_001", "IR_SHL_AUX_0251_001"], "supporting_clauses": ["SHL_SONGBEN_0096", "SHL_SONGBEN_0097", "SHL_SONGBEN_0098", "SHL_SONGBEN_0099", "SHL_SONGBEN_0100", "SHL_SONGBEN_0101", "SHL_SONGBEN_0144", "SHL_SONGBEN_0148", "SHL_SONGBEN_0229", "SHL_SONGBEN_0230", "SHL_SONGBEN_0231", "SHL_SONGBEN_0266", "SHL_SONGBEN_0267", "SHL_SONGBEN_0379", "SHL_SONGBEN_0394", "SHL_SONGBEN_AUX_0251"], "source_level": "inductive_from_original_clauses", "interpretation_warning": "核心證候為跨條文歸納結果；病機類術語（如營衛不和）屬後世歸納，非所有條文原文直述。", "consensus_score": 0.906, "release_level": "gold"}
{"initial_rule_id": "IR_SHL_0096_001", "clause_id": "SHL_SONGBEN_0096", "six_channel": "太陽病", "rule_type": "formula_pattern_rule", "if_conditions": {"disease": ["傷寒", "中風", "痞"], "symptoms": ["往來寒熱", "不欲飲食", "心煩喜嘔", "渴", "腹中痛", "心下悸", "小便不利", "不渴", "微熱"], "negated_findings": ["不嘔"], "pulse": [], "prior_treatment": [], "time_course": ["五六日"]}, "then_conclusions": {"formula": ["小柴胡湯"], "treatment_principle": [], "alternatives": []}, "evidence_span": "傷寒五六日，中風，往來寒熱，胸脇苦滿，嘿嘿不欲飲食，心煩喜嘔。或胸中煩而不嘔，或渴，或腹中痛，或脇下痞鞕，或心下悸、小便不利，或不渴、身有微熱，或欬者，小柴胡湯主之。", "evidence_type": "original_text", "interpretation": "該條可作為小柴胡湯相關方證的原文證據，原文用語為「小柴胡湯主之」，證據強度：主治關係（主之）。", "interpretation_level": "normalized", "model_confidence": 0.9, "prescription_strength": "主之", "autonomous_review": {"evidence_verified": true, "schema_valid": true, "semantic_result": "pass", "critic_result": "pass", "critic_flags": [], "repairs": [], "consensus_score": 0.956, "release_level": "gold"}}
